# Server
PORT=3000
BASE_PATH=/

# Basic Auth (both required to enable)
# AUTH_USERNAME=admin
# AUTH_PASSWORD=changeme

# Redis connection — pick ONE of the three modes below:

# Mode 1: Individual env vars (default)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_TLS=false
# REDIS_NAME=default

# Mode 2: Redis URL (overrides individual vars)
# REDIS_URL=redis://:password@localhost:6379/0
# REDIS_URL=rediss://localhost:6380  # TLS

# Mode 3: Multiple Redis instances JSON (overrides everything above)
# REDIS_INSTANCES='[{"name":"main","host":"redis-1","port":6379},{"name":"jobs","host":"redis-2","port":6379,"password":"secret"}]'

# Queue auto-discovery interval in ms (default: 10000)
QUEUE_DISCOVERY_INTERVAL=10000

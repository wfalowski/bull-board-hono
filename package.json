{
  "name": "bull-board-hono",
  "version": "1.0.0",
  "description": "Lightweight Bull Board dashboard served via Hono.js with multi-Redis support, basic auth, and auto-discovery of queues",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "prepare": "husky",
    "commit": "cz",
    "release": "commit-and-tag-version",
    "release:first": "commit-and-tag-version --first-release",
    "release:dry": "commit-and-tag-version --dry-run"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@bull-board/api": "^6.20.6",
    "@bull-board/hono": "^6.20.6",
    "@hono/node-server": "^1.13.8",
    "bullmq": "^5.34.8",
    "hono": "^4.7.5",
    "ioredis": "^5.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^22.13.14",
    "commit-and-tag-version": "^12.7.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
